BOT_TOKEN=
GROQ_API_KEY=
CLAUDE_API_KEY=
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/transcribe_bot
REDIS_URL=redis://localhost:6379/0
# Dedicated Redis DBs — keep FSM/cache/rate-limit off the Celery broker.
REDIS_CACHE_DB=1
REDIS_FSM_DB=2
REDIS_RATELIMIT_DB=3
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
# Required in webhook mode; used to validate X-Telegram-Bot-Api-Secret-Token.
WEBHOOK_SECRET=
WEBHOOK_HOST=https://bot.yourdomain.ru
ADMIN_IDS=123456789,987654321
ENV=production
SENTRY_DSN=
DB_PASSWORD=secret
# DB pool (ignored for SQLite)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
# Celery hard limits (seconds)
CELERY_SOFT_TIME_LIMIT=1800
CELERY_TIME_LIMIT=2100
# URL-source limits
MAX_URL_DURATION_SECONDS=14400
MAX_URL_FILESIZE_BYTES=2147483648
# Comma-separated allowed origins; empty disables CORS entirely.
CORS_ALLOWED_ORIGINS=
