### --- Core ---
BOT_TOKEN=
# Bot @username (without @) — required for Telegram Login Widget on web.
BOT_USERNAME=your_bot_username

# WEBHOOK_HOST: где Telegram должен слать апдейты.
# - Если api.telegram.org доступен с сервера и сервер publicly reachable —
#   ставьте свой основной домен: https://bot.example.com
# - Если api.telegram.org заблокирован (типичный RU VPS) — поднимите
#   Deno/CF Worker по шаблону scripts/telegram_webhook_proxy_worker.js,
#   и впишите URL прокси: https://<project>.deno.net
# Бот при старте сам вызывает set_webhook на этот URL.
WEBHOOK_HOST=https://bot.yourdomain.ru

# Required in webhook mode; validates X-Telegram-Bot-Api-Secret-Token.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
WEBHOOK_SECRET=

DOMAIN=bot.yourdomain.ru
ENV=production

### --- External APIs ---
GROQ_API_KEY=
# По умолчанию — official endpoint. На RU/CN сервере api.groq.com обычно
# заблокирован — поднимите CF Worker (scripts/groq_proxy_worker.js,
# рекомендуется) или Deno Deploy (scripts/groq_proxy_deno.js, free tier
# периодически таймаутит на больших файлах) и впишите его URL без слэша
# в конце:
#   GROQ_API_BASE=https://<your-proxy-host>
GROQ_API_BASE=https://api.groq.com

# OpenRouter — единый ключ для Claude / GPT / Gemini / Llama через общий
# OpenAI-совместимый API. Используется для генерации саммари.
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Примеры моделей: anthropic/claude-3.5-haiku, openai/gpt-4o-mini,
#                  google/gemini-2.5-flash, meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# HTTP/SOCKS5 прокси для yt-dlp. По умолчанию пусто — yt-dlp ходит напрямую.
# ⚠️ Применяется ко ВСЕМ загрузкам, не только к одному домену. Если ставите
# ради конкретного сервиса — лучше отключить его в whitelist (validators.py).
# Примеры:
#   YDL_PROXY=http://user:pass@host:port
#   YDL_PROXY=socks5://host:1080
#   YDL_PROXY=socks5h://172.18.0.1:40000   # WARP через socat-форвардер
YDL_PROXY=

YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# 54-ФЗ ставка НДС: 1=без НДС (УСН), 2=0%, 6=20%
YUKASSA_VAT_CODE=1

### --- Storage ---
DATABASE_URL=postgresql+asyncpg://bot:${DB_PASSWORD}@db/transcribe_bot
DB_PASSWORD=change-me-long-random
# Размер пула на ПРОЦЕСС. На worker'ах используется NullPool (см. db/base.py),
# поэтому реально применяется только к bot/api/beat. Postgres настроен на
# max_connections=80 (см. docker-compose.yml).
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_FSM_DB=2
REDIS_RATELIMIT_DB=3

### --- S3 (optional, not required in current flow) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

### --- Admins (required for 2FA: at least 2 ids) ---
ADMIN_IDS=111111111,222222222
# TTL of pending admin approvals in seconds.
ADMIN_APPROVAL_TTL_SECONDS=300

### --- Monitoring ---
SENTRY_DSN=

### --- Limits ---
# 4 hours max audio per URL.
MAX_URL_DURATION_SECONDS=14400
# 2 GiB max file size from URL.
MAX_URL_FILESIZE_BYTES=2147483648
# Celery soft/hard time limits per task. soft=1800 даёт shutdown 30 мин на
# graceful decode + transcribe; hard=2100 — kill через 5 мин буфера.
CELERY_SOFT_TIME_LIMIT=1800
CELERY_TIME_LIMIT=2100
# Сколько дней хранить result_text в БД до purge.
TRANSCRIPTION_RETENTION_DAYS=3
# Сколько дней pg_dump-архивов хранить в db_backups volume.
BACKUP_RETENTION_DAYS=14

### --- Web auth (JWT) ---
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Max file size for web uploads (default 500 MB, smaller than bot's 2 GB).
MAX_UPLOAD_BYTES=524288000

### --- CORS ---
# Admin panel + public web app — список через запятую.
CORS_ALLOWED_ORIGINS=https://littera.site,https://sb.littera.site

### --- Legal boilerplate (used by /privacy and /terms) ---
# ⚠️ Кириллические значения с пробелами обязательно в кавычках, иначе
# `source .env` в bash попытается выполнить вторую часть как команду.
# docker compose читает корректно — это спасает только ручной source.
COMPANY_NAME="ИП Иванов И.И."
COMPANY_INN=000000000000
COMPANY_OGRN=0000000000000
COMPANY_ADDRESS="г. Москва"
SUPPORT_EMAIL=support@yourdomain.ru
# Telegram-handle живой поддержки (без @).
SUPPORT_HANDLE=littera_support
PRIVACY_POLICY_URL=https://yourdomain.ru/privacy
TERMS_URL=https://yourdomain.ru/terms
